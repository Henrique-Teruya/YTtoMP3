# ============================================
# YTMP3 PRO — Environment Configuration
# ============================================
# Copy this file to .env and adjust values:
#   cp .env.example .env
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Paths (leave empty to use system PATH)
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg

# Downloads
DOWNLOAD_DIR=./backend/downloads
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_TIMEOUT_MS=300000
FILE_RETENTION_MINUTES=30
MAX_PLAYLIST_TRACKS=50

# Security
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_CONVERT=10
RATE_LIMIT_MAX_INFO=30

# Logging
LOG_LEVEL=info
