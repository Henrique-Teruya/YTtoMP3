{
  "name": "ytmp3-pro",
  "version": "1.1.0",
  "description": "YTMP3 PRO — Professional YouTube to Audio Desktop App",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder build --win --publish never",
    "check:deps": "node -e \"const { execSync } = require('child_process'); try { execSync('yt-dlp --version', {stdio:'pipe'}); console.log('✓ yt-dlp found'); } catch { console.error('✗ yt-dlp not found'); } try { execSync('ffmpeg -version', {stdio:'pipe'}); console.log('✓ ffmpeg found'); } catch { console.error('✗ ffmpeg not found'); }\""
  },
  "build": {
    "appId": "com.ytmp3.pro",
    "productName": "YTMP3 PRO",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "backend/**/*",
      "frontend/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "frontend/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YTMP3 PRO",
      "installerIcon": "frontend/assets/icon.ico",
      "uninstallerIcon": "frontend/assets/icon.ico"
    }
  },
  "keywords": [
    "youtube",
    "mp3",
    "wav",
    "audio",
    "converter",
    "yt-dlp",
    "ffmpeg",
    "downloader"
  ],
  "author": "YTMP3 PRO",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
